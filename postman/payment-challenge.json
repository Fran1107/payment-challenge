        {
            "name": "🔐 Auth",
            "item": [
                {
                    "name": "01 - Obtener token (credenciales válidas)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Tiene access_token', () => {",
                                    "  const body = pm.response.json();",
                                    "  pm.expect(body.access_token).to.be.a('string');",
                                    "  pm.expect(body.token_type).to.eql('Bearer');",
                                    "  pm.collectionVariables.set('token', body.access_token);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/token",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"client_id\": \"payment_client\",\n  \"client_secret\": \"s3cr3t_key\"\n}"
                        }
                    }
                },
                {
                    "name": "02 - Token con credenciales inválidas → 401",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 401', () => pm.response.to.have.status(401));",
                                    "pm.test('Error UNAUTHORIZED', () => {",
                                    "  pm.expect(pm.response.json().error).to.eql('UNAUTHORIZED');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/token",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }

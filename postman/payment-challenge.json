                    "name": "21 - Consultar transacción existente",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Retorna los campos correctos', () => {",
                                    "  const b = pm.response.json();",
                                    "  pm.expect(b.transaction_id).to.be.a('string');",
                                    "  pm.expect(b.status).to.be.oneOf(['approved', 'declined']);",
                                    "  pm.expect(b.card_number).to.match(/^\\d{6} \\*{4} \\d{4}$/);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/payments/{{transaction_id}}",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "22 - Consultar transacción inexistente → 404",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 404', () => pm.response.to.have.status(404));",
                                    "pm.test('NOT_FOUND', () => {",
                                    "  pm.expect(pm.response.json().error).to.eql('NOT_FOUND');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/payments/00000000-0000-0000-0000-000000000000",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "23 - Consultar sin token → 401",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 401', () => pm.response.to.have.status(401));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/payments/{{transaction_id}}"
                    }
                }
            ]
        }
    ]
}